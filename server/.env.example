# Вариант для Mail.ru через STARTTLS, чаще всего лучше пробовать его первым
SMTP_HOST=smtp.mail.ru
SMTP_PORT=587
SMTP_SECURE=false
SMTP_STARTTLS=true
SMTP_USER=your_mail@mail.ru
SMTP_PASS=your_external_app_password
ADMIN_EMAIL=your_mail@mail.ru
CLIENT_URL=http://localhost:3000
PORT=5000

# Если порт 587 не работает, можно попробовать 465:
# SMTP_HOST=smtp.mail.ru
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_STARTTLS=false
