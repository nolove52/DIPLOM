# Почта-отправитель Mail.ru
# ВАЖНО: SMTP_PASS нельзя придумать. Его нужно создать в настройках Mail.ru как пароль для внешнего приложения.
SMTP_HOST=smtp.mail.ru
SMTP_PORT=587
SMTP_SECURE=false
SMTP_STARTTLS=true
SMTP_USER=nolove.vanlav@mail.ru
SMTP_PASS=ВСТАВЬ_СЮДА_ПАРОЛЬ_ДЛЯ_ВНЕШНЕГО_ПРИЛОЖЕНИЯ_MAIL_RU
ADMIN_EMAIL=nolove.vanlav@mail.ru
CLIENT_URL=http://localhost:3000
PORT=5000
